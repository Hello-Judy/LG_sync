{
  "manifest_version": 3,
  "name": "LG Sync — LeetCode GitHub Sync",
  "version": "1.0.0",
  "description": "自动将 LeetCode 提交记录同步到 GitHub，生成刷题看板",

  "permissions": [
    "storage",
    "notifications"
  ],

  "host_permissions": [
    "https://leetcode.com/*",
    "https://api.github.com/*"
  ],

  "background": {
    "service_worker": "src/background.js"
  },

  "content_scripts": [
    {
      "matches": ["https://leetcode.cn/problems/*", "https://leetcode.com/problems/*"],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}